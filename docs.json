            ]
          },
          {
            "group": "Core concepts",
            "icon": "book",
            "pages": [
              "concepts/parameters",
              "concepts/layers",
              "concepts/policies",
              "concepts/projects-and-environments",
              "concepts/events-and-metrics",
              "concepts/assignments",
              "concepts/warehouse-native"
            ]
          },
          {
            "group": "Experimentation",
            "icon": "flask",
            "pages": [
              "experimentation/feature-flags",
              "experimentation/ab-testing",
              "experimentation/rollouts",
              "experimentation/optimization"
            ]
          },
          {
            "group": "Guides",
            "icon": "compass",
            "pages": [
              "guides/canonical-experiments",
              "guides/experiment-design",
              "guides/type-safe-events"
            ]
          },
          {
            "group": "Dashboard",
            "icon": "table-columns",
            "pages": [
              "dashboard/overview",
              "dashboard/parameters",
              "dashboard/layers-and-policies",
              "dashboard/events",
              "dashboard/definitions",
              "dashboard/metrics",
              "dashboard/policy-health",
              "dashboard/pipeline",
              "dashboard/decisions",
              "dashboard/settings"
            ]
          },
          {
            "group": "Warehouse connectors",
            "icon": "plug",
            "pages": [
              "connectors/overview",
              "connectors/postgres",
              "connectors/bigquery",
              "connectors/snowflake",
              "connectors/databricks",
              "connectors/clickhouse"
            ]
          },
          {
            "group": "Developer tools",
            "icon": "terminal",
            "pages": ["tools/cli", "tools/visual-editor", "tools/devtools"]
          },
          {
            "group": "Reference",
            "icon": "book-open",
            "pages": ["reference/glossary"]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "Overview",
            "pages": ["sdks/overview"]
