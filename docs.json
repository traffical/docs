          {
            "group": "Client SDKs",
            "pages": ["sdks/javascript", "sdks/react", "sdks/svelte", "sdks/react-native"]
          },
          {
            "group": "Patterns",
            "pages": ["sdks/ssr"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api/overview"]
          },
          {
            "group": "SDK API",
            "pages": [
              "api/get-config",
              "api/post-resolve",
              "api/post-decide",
              "api/post-events"
            ]
          }
        ]
      }
